---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAdminSession, verifyAdminCsrf } from "@/lib/auth";
import {
  createCategory,
  deleteCategoryAndImages,
  ensureDefaultSettings,
  getTotalQuestions,
  listCategories,
  listCategorySummaries,
  updateCategory
} from "@/lib/store";
import { categorySchema } from "@/lib/validation";
import CircleAlert from "@lucide/astro/icons/circle-alert";
import CircleCheck from "@lucide/astro/icons/circle-check";
import ClipboardList from "@lucide/astro/icons/clipboard-list";
import Grid2x2 from "@lucide/astro/icons/grid-2x2";
import Plus from "@lucide/astro/icons/plus";
import Save from "@lucide/astro/icons/save";
import Trash2 from "@lucide/astro/icons/trash-2";

const session = getAdminSession(Astro.cookies);
if (!session) {
  return Astro.redirect("/admin/login");
}

let message = "";
let messageType: "error" | "success" = "success";

const queryMessage = Astro.url.searchParams.get("status");
if (queryMessage === "created") {
  message = "Categoria creada correctamente.";
} else if (queryMessage === "updated") {
  message = "Categoria actualizada correctamente.";
} else if (queryMessage === "deleted") {
  message = "Categoria eliminada correctamente.";
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const verified = verifyAdminCsrf(Astro.cookies, formData);
  if (!verified) {
    return new Response("Token CSRF invalido.", { status: 403 });
  }

  const intent = formData.get("intent");

  if (intent === "create") {
    const parsed = categorySchema.safeParse({ name: formData.get("name") });
    if (!parsed.success) {
      message = parsed.error.issues[0]?.message ?? "Categoria invalida.";
      messageType = "error";
    } else if (listCategories().some((category) => category.name.toLowerCase() === parsed.data.name.toLowerCase())) {
      message = "Ya existe una categoria con ese nombre.";
      messageType = "error";
    } else {
      createCategory(parsed.data.name);
      return Astro.redirect("/admin/categorias?status=created");
    }
  } else if (intent === "update") {
    const categoryId = Number(formData.get("categoryId"));
    const parsed = categorySchema.safeParse({ name: formData.get("name") });
    if (!Number.isInteger(categoryId) || categoryId <= 0) {
      message = "Categoria invalida.";
      messageType = "error";
    } else if (!parsed.success) {
      message = parsed.error.issues[0]?.message ?? "Categoria invalida.";
      messageType = "error";
    } else {
      const result = updateCategory(categoryId, parsed.data.name);
      if (result === "duplicate") {
        message = "Ya existe una categoria con ese nombre.";
        messageType = "error";
      } else if (result === "not-found") {
        message = "Categoria no encontrada.";
        messageType = "error";
      } else {
        return Astro.redirect("/admin/categorias?status=updated");
      }
    }
  } else if (intent === "delete") {
    const categoryId = Number(formData.get("categoryId"));
    if (!Number.isInteger(categoryId) || categoryId <= 0) {
      message = "Categoria invalida.";
      messageType = "error";
    } else {
      const result = await deleteCategoryAndImages(categoryId);
      if (result === "not-found") {
        message = "Categoria no encontrada.";
        messageType = "error";
      } else {
        return Astro.redirect("/admin/categorias?status=deleted");
      }
    }
  }
}

const settings = ensureDefaultSettings();
const categories = listCategorySummaries();
const totalQuestions = getTotalQuestions();
const readyCategories = categories.filter((category) => category.questionCount >= settings.questionsPerGame);
const pendingCategories = categories.filter((category) => category.questionCount < settings.questionsPerGame);
---

<AdminLayout title="Categorias" active="categories" csrfToken={session.csrfToken}>
  <section class="space-y-6">
    <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
      <div>
        <h1 class="text-2xl font-bold text-slate-950 dark:text-white sm:text-3xl">Categorias</h1>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Gestion del banco de categorias del administrador.</p>
      </div>
    </div>

    {message && (
      <p
        role={messageType === "success" ? "status" : "alert"}
        aria-live={messageType === "success" ? "polite" : "assertive"}
        class:list={[
        "rounded-md px-3 py-2 text-sm font-semibold",
        messageType === "success"
          ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
          : "bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-200"
      ]}>
        {message}
      </p>
    )}

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      {[
        { label: "Categorias", value: categories.length, help: "Total registradas", icon: Grid2x2, tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200" },
        { label: "Listas", value: readyCategories.length, help: "Pueden generar simulacro", icon: CircleCheck, tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200" },
        { label: "Pendientes", value: pendingCategories.length, help: "Requieren mas preguntas", icon: CircleAlert, tone: "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200" },
        { label: "Preguntas", value: totalQuestions, help: "Banco total", icon: ClipboardList, tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200" }
      ].map((metric) => {
        const Icon = metric.icon;
        return (
          <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{metric.label}</p>
                <p class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{metric.value}</p>
              </div>
              <span class:list={["grid h-10 w-10 place-items-center rounded-md", metric.tone]}>
                <Icon size={20} aria-hidden="true" />
              </span>
            </div>
            <p class="mt-3 text-xs text-slate-600 dark:text-slate-400">{metric.help}</p>
          </article>
        );
      })}
    </div>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
      <div class="mb-4 flex items-start gap-3">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
          <Plus size={20} aria-hidden="true" />
        </span>
        <div>
          <h2 class="text-lg font-bold text-slate-950 dark:text-white">Nueva categoria</h2>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Crea una categoria para organizar preguntas y simulacros.</p>
        </div>
      </div>

      <form method="post" class="grid gap-3 md:grid-cols-[minmax(0,1fr)_180px]">
        <input type="hidden" name="csrfToken" value={session.csrfToken} />
        <input type="hidden" name="intent" value="create" />
        <label>
          <span class="sr-only">Nombre de categoria</span>
          <input
            class="focus-ring h-12 w-full rounded-md border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-900 placeholder:text-slate-400 dark:border-white/10 dark:bg-slate-950 dark:text-white"
            name="name"
            placeholder="Ej. Matematicas"
            required
            minlength="2"
            maxlength="150"
            data-testid="category-name"
          />
        </label>
        <button class="focus-ring inline-flex h-12 items-center justify-center gap-2 rounded-md bg-orange-600 px-4 text-sm font-bold text-white shadow-sm hover:bg-orange-700" data-testid="create-category">
          <Plus size={16} aria-hidden="true" />
          Crear categoria
        </button>
      </form>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-950 dark:text-white">Banco por categoria</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Minimo actual: {settings.questionsPerGame} preguntas por simulacro.</p>
      </div>

      {categories.length === 0 ? (
        <div class="rounded-lg border border-dashed border-slate-300 p-8 text-center text-sm text-slate-600 dark:border-white/10 dark:text-slate-300">
          Todavia no hay categorias.
        </div>
      ) : (
        <div class="grid gap-3">
          {categories.map((category, index) => {
            const ready = category.questionCount >= settings.questionsPerGame;
            const percent = Math.min(100, Math.round((category.questionCount * 100) / Math.max(settings.questionsPerGame, 1)));
            return (
              <article class="rounded-lg border border-slate-200 p-4 dark:border-white/10" data-testid="category-card">
                <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_200px_280px] xl:items-center">
                  <div class="flex min-w-0 gap-3">
                    <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-orange-50 text-sm font-black text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <div class="min-w-0">
                      <h3 class="font-bold text-slate-950 dark:text-white">{category.name}</h3>
                      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{category.questionCount} preguntas</p>
                    </div>
                  </div>

                  <div>
                    <div class="mb-1 flex justify-between text-xs font-bold text-slate-500 dark:text-slate-400">
                      <span>{percent}% minimo</span>
                      <span>{settings.questionsPerGame}</span>
                    </div>
                    <div class="h-2 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800">
                      <div class:list={["h-full rounded-md", ready ? "bg-emerald-500" : "bg-orange-500"]} style={`width: ${percent}%`}></div>
                    </div>
                  </div>

                  <div class="flex flex-col gap-2">
                    <div class="flex items-center justify-between gap-3 xl:justify-end">
                      <span class:list={[
                        "rounded-md px-2.5 py-1 text-xs font-bold",
                        ready
                          ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                          : "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
                      ]}>
                        {ready ? "Lista" : "Incompleta"}
                      </span>
                      <a href="/admin/preguntas" class="focus-ring rounded-md border border-slate-200 px-3 py-2 text-sm font-bold text-slate-700 hover:border-orange-200 hover:text-orange-700 dark:border-white/10 dark:text-slate-200 dark:hover:text-orange-200">
                        Preguntas
                      </a>
                    </div>

                    <form method="post" class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_44px]">
                      <input type="hidden" name="csrfToken" value={session.csrfToken} />
                      <input type="hidden" name="intent" value="update" />
                      <input type="hidden" name="categoryId" value={category.id} />
                      <label>
                        <span class="sr-only">Editar {category.name}</span>
                        <input
                          class="focus-ring h-10 w-full rounded-md border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-900 dark:border-white/10 dark:bg-slate-950 dark:text-white"
                          name="name"
                          value={category.name}
                          required
                          minlength="2"
                          maxlength="150"
                          data-testid="edit-category-name"
                        />
                      </label>
                      <button class="focus-ring grid h-10 w-11 place-items-center rounded-md border border-emerald-200 text-emerald-700 hover:bg-emerald-50 dark:border-emerald-400/30 dark:text-emerald-200 dark:hover:bg-emerald-500/10" aria-label={`Guardar ${category.name}`} data-testid="update-category">
                        <Save size={16} aria-hidden="true" />
                      </button>
                    </form>

                    <form
                      method="post"
                      class="flex justify-end"
                      data-confirm-message={`Eliminar ${category.name} tambien eliminara sus preguntas asociadas. Deseas continuar?`}
                    >
                      <input type="hidden" name="csrfToken" value={session.csrfToken} />
                      <input type="hidden" name="intent" value="delete" />
                      <input type="hidden" name="categoryId" value={category.id} />
                      <button
                        class="focus-ring inline-flex items-center gap-2 rounded-md border border-red-200 px-3 py-2 text-sm font-bold text-red-700 hover:bg-red-50 dark:border-red-400/30 dark:text-red-200 dark:hover:bg-red-500/10"
                        aria-label={`Eliminar ${category.name}`}
                        data-testid="delete-category"
                        title={category.questionCount > 0 ? "Elimina la categoria y sus preguntas asociadas." : "Eliminar categoria"}
                      >
                        <Trash2 size={16} aria-hidden="true" />
                        Eliminar
                      </button>
                    </form>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </section>
  </section>
</AdminLayout>
