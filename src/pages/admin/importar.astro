---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAdminSession, verifyAdminCsrf } from "@/lib/auth";
import { isAllowedCsvUpload, parseQuestionCsv, type ImportParseError } from "@/lib/questionImport";
import { importQuestionRows, listCategorySummaries } from "@/lib/store";
import CircleAlert from "@lucide/astro/icons/circle-alert";
import CircleCheck from "@lucide/astro/icons/circle-check";
import FileUp from "@lucide/astro/icons/file-up";
import Grid2x2 from "@lucide/astro/icons/grid-2x2";

const session = getAdminSession(Astro.cookies);
if (!session) {
  return Astro.redirect("/admin/login");
}

let message = "";
let messageType: "error" | "success" = "success";
let importErrors: ImportParseError[] = [];
const maxCsvSize = 1024 * 1024;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const verified = verifyAdminCsrf(Astro.cookies, formData);
  if (!verified) {
    return new Response("Token CSRF invalido.", { status: 403 });
  }

  const file = formData.get("csv");
  if (!(file instanceof File) || file.size === 0) {
    message = "Selecciona un archivo CSV para importar.";
    messageType = "error";
  } else if (!isAllowedCsvUpload(file)) {
    message = "El archivo debe tener extension .csv.";
    messageType = "error";
  } else if (file.size > maxCsvSize) {
    message = "El archivo supera 1 MB. Divide la carga en archivos mas pequenos.";
    messageType = "error";
  } else {
    const parsed = parseQuestionCsv(await file.text());
    if (!parsed.ok) {
      message = `No se importo nada. Corrige ${parsed.errors.length === 1 ? "el error detectado" : "los errores detectados"} y vuelve a subir el CSV.`;
      messageType = "error";
      importErrors = parsed.errors.slice(0, 20);
    } else {
      const summary = importQuestionRows(parsed.rows);
      message = `Importacion lista: ${summary.createdQuestions} preguntas creadas, ${summary.skippedDuplicates} duplicadas omitidas y ${summary.createdCategories} categorias nuevas.`;
      messageType = "success";
    }
  }
}

const categories = listCategorySummaries();
const totalQuestions = categories.reduce((sum, category) => sum + category.questionCount, 0);
const sampleCsv = [
  "categoria,pregunta,opcion_a,opcion_b,opcion_c,opcion_d,respuesta_correcta",
  "Razonamiento verbal,\"Que opcion completa la analogia?\",Leer,Escribir,Calcular,Dibujar,B"
].join("\n");
---

<AdminLayout title="Importar" active="import" csrfToken={session.csrfToken}>
  <section class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-950 dark:text-white sm:text-3xl">Importar</h1>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Carga masiva de preguntas desde CSV validado antes de guardar.</p>
    </div>

    {message && (
      <section
        role={messageType === "success" ? "status" : "alert"}
        aria-live={messageType === "success" ? "polite" : "assertive"}
        class:list={[
          "rounded-lg border p-4",
          messageType === "success"
            ? "border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-400/30 dark:bg-emerald-500/15 dark:text-emerald-100"
            : "border-red-200 bg-red-50 text-red-800 dark:border-red-400/30 dark:bg-red-500/15 dark:text-red-100"
        ]}
      >
        <div class="flex items-start gap-3">
          <span class="mt-0.5 shrink-0">
            {messageType === "success" ? <CircleCheck size={18} aria-hidden="true" /> : <CircleAlert size={18} aria-hidden="true" />}
          </span>
          <div class="min-w-0">
            <p class="text-sm font-bold">{message}</p>
            {importErrors.length > 0 && (
              <ul class="mt-3 space-y-1 text-sm">
                {importErrors.map((error) => (
                  <li>Linea {error.line}: {error.message}</li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </section>
    )}

    <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_340px]">
      <article class="min-w-0 rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
        <div class="flex items-start gap-4">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
            <FileUp size={24} aria-hidden="true" />
          </span>
          <div class="min-w-0 flex-1">
            <h2 class="text-lg font-bold text-slate-950 dark:text-white">Carga masiva</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600 dark:text-slate-400">
              Sube un CSV con encabezados. Si hay errores de formato, no se guarda ninguna fila.
            </p>

            <form method="post" enctype="multipart/form-data" class="mt-5 space-y-4">
              <input type="hidden" name="csrfToken" value={session.csrfToken} />

              <label class="block">
                <span class="text-sm font-bold text-slate-800 dark:text-slate-100">Archivo CSV</span>
                <input
                  class="focus-ring mt-2 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 file:mr-3 file:rounded-md file:border-0 file:bg-slate-100 file:px-3 file:py-2 file:text-sm file:font-bold file:text-slate-700 hover:file:bg-slate-200 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:file:bg-white/10 dark:file:text-slate-100"
                  type="file"
                  name="csv"
                  accept=".csv,text/csv"
                  required
                  data-testid="import-csv-file"
                />
              </label>

              <button class="focus-ring inline-flex min-h-11 items-center justify-center gap-2 rounded-md bg-orange-600 px-4 text-sm font-bold text-white hover:bg-orange-700" data-testid="import-csv-submit">
                <FileUp size={16} aria-hidden="true" />
                Importar preguntas
              </button>
            </form>
          </div>
        </div>
      </article>

      <aside class="min-w-0 space-y-4">
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
          <div class="flex items-start gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">
              <Grid2x2 size={20} aria-hidden="true" />
            </span>
            <div>
              <h2 class="font-bold text-slate-950 dark:text-white">Banco actual</h2>
              <p class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{categories.length}</p>
              <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">{totalQuestions} preguntas registradas</p>
            </div>
          </div>
        </article>

        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
          <h2 class="font-bold text-slate-950 dark:text-white">Formato requerido</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
            Columnas: categoria, pregunta, opcion_a, opcion_b, opcion_c, opcion_d y respuesta_correcta. La respuesta debe ser A, B, C o D.
          </p>
          <pre class="mt-3 max-w-full overflow-x-auto rounded-md bg-slate-950 p-3 text-xs leading-5 text-slate-100"><code>{sampleCsv}</code></pre>
        </article>
      </aside>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
      <h2 class="text-lg font-bold text-slate-950 dark:text-white">Reglas de importacion</h2>
      <div class="mt-4 grid gap-3 md:grid-cols-3">
        {[
          { title: "Validacion previa", text: "Si una fila falla, no se guarda ninguna pregunta del archivo." },
          { title: "Categorias automaticas", text: "Si la categoria no existe, se crea antes de guardar sus preguntas." },
          { title: "Duplicados omitidos", text: "Si ya existe la misma pregunta en la categoria, se omite sin borrar datos." }
        ].map((item) => (
          <div class="rounded-lg border border-slate-200 p-4 dark:border-white/10">
            <h3 class="text-sm font-black text-slate-950 dark:text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">{item.text}</p>
          </div>
        ))}
      </div>
    </section>
  </section>
</AdminLayout>
