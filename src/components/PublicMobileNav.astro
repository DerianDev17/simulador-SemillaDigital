---
import Grid2x2 from "@lucide/astro/icons/grid-2x2";
import History from "@lucide/astro/icons/history";
import House from "@lucide/astro/icons/house";
import Trophy from "@lucide/astro/icons/trophy";

type PublicMobileNavActive = "home" | "categories" | "simulations" | "history";

interface Props {
  active: PublicMobileNavActive;
}

const { active } = Astro.props;

const items = [
  { id: "home", label: "Inicio", href: "/", icon: House },
  { id: "categories", label: "Categorias", href: "/categorias", icon: Grid2x2 },
  { id: "simulations", label: "Simulacros", href: "/simulacros", icon: Trophy },
  { id: "history", label: "Historial", href: "/historial", icon: History }
] satisfies Array<{ id: PublicMobileNavActive; label: string; href: string; icon: typeof House }>;
---

<nav class="fixed inset-x-3 bottom-[calc(0.75rem+env(safe-area-inset-bottom))] z-30 rounded-lg border border-slate-200 bg-white/95 p-1 shadow-lg backdrop-blur dark:border-white/10 dark:bg-slate-950/95 lg:hidden" aria-label="Navegacion publica movil">
  <div class="grid grid-cols-4">
    {items.map((item) => {
      const Icon = item.icon;
      const isActive = active === item.id;
      return (
        <a
          href={item.href}
          aria-current={isActive ? "page" : undefined}
          class:list={[
            "focus-ring flex flex-col items-center gap-1 rounded-md px-1 py-2 text-[11px] font-semibold",
            isActive
              ? "text-orange-700 dark:text-orange-200"
              : "text-slate-600 hover:bg-slate-100 hover:text-slate-950 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white"
          ]}
        >
          <Icon size={18} aria-hidden="true" />
          <span>{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>
